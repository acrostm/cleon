// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
}

model Post {
  id           String   @id @default(uuid())
  originalUrl  String
  platform     String
  authorName   String
  avatarUrl    String
  title        String?  @db.Text
  contentText  String
  mediaUrls    String[]
  createdAt    DateTime @default(now())

  @@index([createdAt])
}

model UrlSubmission {
  id           String   @id @default(uuid())
  url          String
  source       String   // "FEISHU" or "WEB"
  status       String   // "SUCCESS", "FAILED", "DUPLICATE", "REJECTED"
  postId       String?  // References Post.id if successful
  errorMessage String?  @db.Text
  createdAt    DateTime @default(now())

  @@index([createdAt])
  @@index([url])
}
